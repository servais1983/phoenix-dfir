# Phoenix DFIR - Configuration
# Copier ce fichier en .env et personnaliser les valeurs

# Cle secrete pour les tokens JWT (generee automatiquement si vide)
PHOENIX_SECRET_KEY=

# Duree de validite des tokens en secondes (defaut: 24h)
PHOENIX_TOKEN_EXPIRY=86400

# Mode debug (ne JAMAIS activer en production)
PHOENIX_DEBUG=false

# Port du serveur
PHOENIX_PORT=5000
