# Phoenix DFIR - Configuration de Production
# Copier ce fichier en .env et remplir toutes les valeurs OBLIGATOIRES
# NE JAMAIS committer le fichier .env dans git !

# ============================================================================
# SECURITE - OBLIGATOIRE
# ============================================================================

# Cle secrete pour les tokens JWT (MINIMUM 64 caracteres aleatoires)
# Generer avec: python3 -c "import secrets; print(secrets.token_hex(64))"
# ou:           openssl rand -hex 64
PHOENIX_SECRET_KEY=

# ============================================================================
# TOKENS JWT
# ============================================================================

# Duree de validite de l'access token en secondes (defaut: 1h)
PHOENIX_TOKEN_EXPIRY=3600

# Duree de validite du refresh token en secondes (defaut: 7 jours)
PHOENIX_REFRESH_EXPIRY=604800

# ============================================================================
# PROTECTION ANTI-BRUTE FORCE
# ============================================================================

# Nombre de tentatives echouees avant verrouillage (defaut: 5)
PHOENIX_MAX_FAILED_ATTEMPTS=5

# Duree du verrouillage en secondes (defaut: 15 minutes)
PHOENIX_LOCKOUT_DURATION=900

# ============================================================================
# SERVEUR
# ============================================================================

# Mode debug (JAMAIS true en production - expose les stack traces)
PHOENIX_DEBUG=false

# Port du backend Flask/Gunicorn
PHOENIX_PORT=5000

# Port expose par nginx (front)
NGINX_PORT=80

# Niveau de log: DEBUG, INFO, WARNING, ERROR
PHOENIX_LOG_LEVEL=INFO

# Format de log: json (production) ou text (developpement)
PHOENIX_LOG_FORMAT=json

# ============================================================================
# CORS - IMPORTANT POUR LA PRODUCTION
# ============================================================================

# Origines autorisees (separees par des virgules, PAS d'espace)
# En production: mettre exactement l'URL de votre domaine
# Exemple: https://dfir.mondomaine.com
CORS_ORIGINS=http://localhost:80,http://localhost

# ============================================================================
# FRONTEND (Vite)
# ============================================================================

# URL de l'API pour le frontend
# En production derriere nginx: laisser vide ou mettre /api
# En dev: http://localhost:5000/api
VITE_API_URL=

# ============================================================================
# PROXY (si nginx ou load balancer en front)
# ============================================================================

# Faire confiance aux headers X-Forwarded-For
# Activer UNIQUEMENT si un proxy de confiance est devant le backend
PHOENIX_TRUST_PROXY=true

# IPs autorisees a definir X-Forwarded-For (gunicorn)
GUNICORN_FORWARDED_IPS=127.0.0.1

# ============================================================================
# GUNICORN (serveur WSGI production)
# ============================================================================

# Nombre de workers (auto si non defini: CPUs*2+1, max 8)
GUNICORN_WORKERS=4

# Niveau de log gunicorn
GUNICORN_LOG_LEVEL=info

# ============================================================================
# STOCKAGE
# ============================================================================

# Duree de retention des fichiers uploades en heures (defaut: 24h)
PHOENIX_UPLOAD_RETENTION_HOURS=24

# Chemin de la base de donnees SQLite (optionnel, defaut: backend/phoenix.db)
# PHOENIX_DB_PATH=/app/data/phoenix.db

# ============================================================================
# INTELLIGENCE ARTIFICIELLE (optionnel)
# ============================================================================

# Cle API Google Gemini (pour les analyses IA)
GOOGLE_AI_API_KEY=

# ============================================================================
# NOTES DE SECURITE PRODUCTION
# ============================================================================
# 1. PHOENIX_SECRET_KEY doit etre unique, aleatoire, et >= 64 chars
# 2. CORS_ORIGINS doit lister UNIQUEMENT vos domaines de confiance
# 3. PHOENIX_DEBUG doit etre false
# 4. Utiliser HTTPS en production (configurer un certificat SSL dans nginx)
# 5. Sauvegarder regulierement le volume phoenix-data (contient la DB SQLite)
# 6. Surveiller les logs d'audit (/api/audit) pour detecter les anomalies
