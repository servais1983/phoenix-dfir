# Phoenix DFIR - Production environment template
# Copier ce fichier en .env puis ajuster les valeurs.
# Le .env ne doit JAMAIS etre commit (il est ignore par .gitignore).

# === Secret JWT (OBLIGATOIRE en prod) ===
# Generer une cle longue : python -c "import secrets; print(secrets.token_hex(64))"
PHOENIX_SECRET_KEY=

# === Tokens v4 ===
# Duree des access tokens (secondes) - defaut 900 = 15 min
PHOENIX_ACCESS_TOKEN_EXPIRY=900
# Duree des refresh tokens (secondes) - defaut 604800 = 7 jours
PHOENIX_REFRESH_TOKEN_EXPIRY=604800
# Retro-compat v3 : si defini, override ACCESS_TOKEN_EXPIRY
# PHOENIX_TOKEN_EXPIRY=86400

# === Hashing des mots de passe ===
# Iterations PBKDF2 - augmenter quand le hardware progresse
PHOENIX_PBKDF2_ITERATIONS=600000

# === Logging ===
# DEBUG, INFO, WARNING, ERROR
PHOENIX_LOG_LEVEL=INFO

# === Cache & rate limit distribue ===
# Si vide, fallback in-memory (non-recommande en multi-worker)
# REDIS_URL=redis://redis:6379/0

# === Analyse IA : GitHub Copilot (API GitHub Models) ===
# Jeton GitHub (fine-grained PAT avec la permission "Models: read",
# https://github.com/settings/tokens). L'acces GitHub Models est inclus
# avec les comptes GitHub / abonnements Copilot.
# GITHUB_TOKEN=
# Modele a utiliser (catalogue : https://github.com/marketplace/models)
# PHOENIX_GITHUB_MODEL=openai/gpt-4o-mini
# Fournisseur IA : github (defaut) | ollama | gemini
# PHOENIX_AI_PROVIDER=github

# === Mode debug (JAMAIS true en prod) ===
PHOENIX_DEBUG=false

# === Port du serveur (single-container) ===
PHOENIX_PORT=5000

# === Ports d'expose (stack docker-compose.prod.yml) ===
PHOENIX_HTTP_PORT=80
PHOENIX_HTTPS_PORT=443

# === Image tag ===
PHOENIX_VERSION=4.0
